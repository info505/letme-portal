generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PortalUserRole {
  ADMIN
  ORDERER
  FINANCE
}

enum PortalOrderStatus {
  OPEN
  CONFIRMED
  IN_PREPARATION
  DELIVERED
  CANCELLED
}

enum RecurringInterval {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum InvoiceStatus {
  OFFEN
  BEZAHLT
  UEBERFAELLIG
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model PortalUser {
  id                     String         @id @default(cuid())
  companyName            String
  firstName              String
  lastName               String
  username               String         @unique
  email                  String         @unique
  phone                  String?
  passwordHash           String

  isActive               Boolean        @default(false)
  isAdmin                Boolean        @default(false)
  role                   PortalUserRole @default(ORDERER)
  mustResetPassword      Boolean        @default(false)
  invoicePurchaseEnabled Boolean        @default(false)

  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  billing        BillingProfile?
  addresses      DeliveryAddress[]
  authSessions   PortalSession[]
  resetTokens    PasswordResetToken[]
  costCenters    CostCenter[]
  contacts       PortalContact[]
  locations      PortalLocation[]
  orders         PortalOrder[]
  orderTemplates OrderTemplate[]
  recurringPlans RecurringOrderPlan[]
  invoices       PortalInvoice[]
}

model BillingProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String?
  contactName  String?
  email        String?
  phone        String?
  street       String?
  houseNumber  String?
  postalCode   String?
  city         String?
  country      String?
  vatId        String?
  invoiceEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user PortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortalLocation {
  id          String   @id @default(cuid())
  userId      String
  name        String
  companyName String?
  contactName String?
  phone       String?
  street      String?
  houseNumber String?
  postalCode  String?
  city        String?
  country     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      PortalUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses DeliveryAddress[]
  contacts  PortalContact[]
  orders    PortalOrder[]

  @@index([userId])
}

model DeliveryAddress {
  id          String   @id @default(cuid())
  userId      String
  locationId  String?
  label       String?
  companyName String?
  contactName String?
  phone       String?
  street      String
  houseNumber String?
  postalCode  String
  city        String
  country     String
  notes       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     PortalUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location PortalLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  orders   PortalOrder[]

  @@index([userId])
  @@index([locationId])
}

model PortalContact {
  id         String   @id @default(cuid())
  userId     String
  locationId String?
  firstName  String
  lastName   String?
  email      String
  phone      String?
  roleLabel  String?
  department String?
  isPrimary  Boolean  @default(false)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     PortalUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  location PortalLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  orders   PortalOrder[]

  @@index([userId])
  @@index([locationId])
  @@index([email])
}

model CostCenter {
  id          String   @id @default(cuid())
  userId      String
  name        String
  code        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           PortalUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders         PortalOrder[]
  orderTemplates OrderTemplate[]
  recurringPlans RecurringOrderPlan[]

  @@index([userId])
}

model PortalSession {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user PortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user PortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PortalOrder {
  id          String            @id @default(cuid())
  userId      String
  orderNumber String            @unique
  orderType   String?
  status      PortalOrderStatus @default(OPEN)
  currency    String            @default("EUR")

  billingContactName String?
  billingEmail       String?
  billingPhone       String?
  billingCompanyName String?

  deliveryAddressId String?
  locationId        String?
  contactId         String?
  costCenterId      String?
  referenceNumber   String?

  subtotalAmount Decimal? @db.Decimal(10, 2)
  taxAmount      Decimal? @db.Decimal(10, 2)
  totalAmount    Decimal  @db.Decimal(10, 2)

  notes        String?
  deliveryDate DateTime?
  orderedAt    DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user            PortalUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryAddress DeliveryAddress?  @relation(fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  location        PortalLocation?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  contact         PortalContact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  costCenter      CostCenter?       @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  items           PortalOrderItem[]

  @@index([userId])
  @@index([deliveryAddressId])
  @@index([locationId])
  @@index([contactId])
  @@index([costCenterId])
}

model PortalOrderItem {
  id      String @id @default(cuid())
  orderId String

  title      String
  quantity   Int      @default(1)
  unit       String?
  unitPrice  Decimal? @db.Decimal(10, 2)
  totalPrice Decimal? @db.Decimal(10, 2)
  notes      String?

  shopifyProductId String?
  shopifyVariantId String?
  shopifyHandle    String?
  variantTitle     String?
  sku              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order PortalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([shopifyVariantId])
  @@index([shopifyProductId])
  @@index([shopifyHandle])
  @@index([sku])
}

model OrderTemplate {
  id           String   @id @default(cuid())
  userId       String
  costCenterId String?
  name         String
  description  String?
  orderType    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user           PortalUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  costCenter     CostCenter?          @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  items          OrderTemplateItem[]
  recurringPlans RecurringOrderPlan[]

  @@index([userId])
  @@index([costCenterId])
}

model OrderTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  title      String
  quantity   Int      @default(1)
  unit       String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model RecurringOrderPlan {
  id           String            @id @default(cuid())
  userId       String
  templateId   String
  costCenterId String?
  name         String
  interval     RecurringInterval
  weekday      Int?
  dayOfMonth   Int?
  nextRunAt    DateTime?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user       PortalUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   OrderTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  costCenter CostCenter?   @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([templateId])
  @@index([costCenterId])
}

model PortalInvoice {
  id            String        @id @default(cuid())
  userId        String
  invoiceNumber String
  title         String?
  issueDate     DateTime?
  dueDate       DateTime?
  amountGross   Decimal?      @db.Decimal(10, 2)
  status        InvoiceStatus @default(OFFEN)
  pdfUrl        String
  originalName  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user PortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([invoiceNumber])
}